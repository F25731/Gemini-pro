PORT=3000

# Key used by NewAPI when calling this wrapper. Do not leave empty in production.
WRAPPER_API_KEY=change-me-newapi-key

# Token for /admin. Do not leave empty in production.
ADMIN_TOKEN=change-me-admin-token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-password

# Public wrapper URL shown in admin UI.
PUBLIC_BASE_URL=https://your-domain.example/v1

# GetToken enterprise API key.
BANANA_API_KEY=sk-your-gettoken-key
BANANA_API_BASE=https://nb.gettoken.cn/openapi
RUNTIME_CONFIG_PATH=data/config.json

# NewAPI models: banana-pro-1k / banana-pro-2k / banana-pro-4k.
MODEL_PREFIX=banana-pro

# Concurrency. Start here on your 20-core server, then raise after watching upstream limits.
MAX_WORKERS=512
MAX_QUEUE=20000

# Polling and timeout.
BANANA_POLL_INTERVAL_MS=2500
REQUEST_TIMEOUT_SECONDS=600
BANANA_HTTP_TIMEOUT_SECONDS=60

# Force b64_json response. Default false means only b64 when request asks response_format=b64_json.
RETURN_B64_JSON=false
